  defaultLanguage: zh
  entries:
  - key: dialog.hello
    values:
    - language: zh
      value: "\u4F60\u597D\uFF0C{wave}MText{/wave} \u5DF2\u7ECF\u63A5\u5165\u65B0\u7684\u65F6\u95F4\u8F74\u52A8\u753B\u3002"
    - language: en
      value: Hello, {wave}MText{/wave} now uses timeline driven animation.
  - key: dialog.warning
    values:
    - language: zh
      value: "{color=#ffcc00}\u8B66\u544A{/color}\uFF1A\u53EF\u4EE5\u7ACB\u5373\u5B8C\u6210\u6253\u5B57\u673A\uFF0C\u4E5F\u53EF\u4EE5\u5207\u6362\u8BED\u8A00\u3002"
    - language: en
      value: '{color=#ffcc00}Warning{/color}: finish typewriter instantly or switch
        language.'
  - key: dialog.effects
    values:
    - language: zh
      value: "\u5185\u8054\u6548\u679C\u652F\u6301 {shake}shake{/shake}\u3001{pulse}pulse{/pulse}
        \u548C {wave}wave{/wave}\u3002"
    - language: en
      value: Inline effects include {shake}shake{/shake}, {pulse}pulse{/pulse}, and
        {wave}wave{/wave}.
